{
  "expo": {
    "name": "Restate",
    "slug": "restate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/real-estate.png",
    "scheme": "appwrite-callback-5125efb6-cac3-44b4-9eab-19673417f8dc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sahilhasnain.restate",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/real-estate.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.sahilhasnain.restate"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/real-estate.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/restate-splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Rubik-Bold.ttf",
            "./assets/fonts/Rubik-ExtraBold.ttf",
            "./assets/fonts/Rubik-Light.ttf",
            "./assets/fonts/Rubik-Medium.ttf",
            "./assets/fonts/Rubik-Regular.ttf",
            "./assets/fonts/Rubik-SemiBold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5125efb6-cac3-44b4-9eab-19673417f8dc"
      }
    }
  }
}
